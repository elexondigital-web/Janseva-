# Database
DATABASE_URL=postgresql://janseva:janseva123@localhost:5432/janseva

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_REFRESH_SECRET=your-refresh-secret-change-this
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=janseva-uploads
AWS_REGION=ap-south-1

# App
PORT=3000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# ---- Phase 3: Messaging providers ----

# MSG91 (Transactional SMS — India)
# https://msg91.com — buy a route, register a flow, paste the auth key + flow id + sender id (6-char DLT-approved header)
MSG91_AUTH_KEY=
MSG91_FLOW_ID=
MSG91_SENDER_ID=JNSEVA

# WhatsApp Cloud API (Meta Business)
# https://developers.facebook.com/docs/whatsapp — create an app, attach a phone number, generate a permanent token.
# Phase 3 only sends free-form text inside a 24h customer-service window OR pre-approved templates;
# this code path uses plain text bodies, which Meta accepts only when a session is open.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# SMTP — bulk email via Nodemailer. Works with SES, SendGrid, Mailgun, Zoho, Gmail (with app password).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=JanSeva

# ---- Phase 3: Reports cache TTL ----
# Aggregate report queries are cached in memory for this many milliseconds.
REPORTS_CACHE_TTL_MS=300000
