# ===================================================================
# JanSeva — production environment
# ===================================================================
# Copy this file to `.env` (next to docker-compose.prod.yml) and fill
# every value before running `./deploy.sh`. Comments mark which keys
# are required vs. optional.
# ===================================================================

# ---- Core ---------------------------------------------------------
# Postgres password used inside the compose network.
DB_PASSWORD=change-me-strong-password

# Sign access + refresh tokens. Use two DIFFERENT 32+ byte random strings.
JWT_SECRET=change-me-with-openssl-rand-base64-48
JWT_REFRESH_SECRET=change-me-with-another-openssl-rand-base64-48

# Public URL the frontend is served on. Goes into CORS + welcome emails.
FRONTEND_URL=https://yourdomain.com

# ---- File storage (optional — falls back to local disk) -----------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=janseva-uploads
AWS_REGION=ap-south-1

# ---- Messaging providers (optional, but at least one is recommended)
# MSG91 transactional SMS
MSG91_AUTH_KEY=
MSG91_FLOW_ID=
MSG91_SENDER_ID=JNSEVA

# WhatsApp Cloud API (Meta Business)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# SMTP for transactional + bulk email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=JanSeva

# ---- Reports cache ------------------------------------------------
# How long to cache aggregate report queries (in ms). 0 disables caching.
REPORTS_CACHE_TTL_MS=300000
